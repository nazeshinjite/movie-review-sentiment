# Copy this file to `.env` and fill in real values. `.env` is gitignored --
# never commit API keys to a public repo (version control is a graded item).
#
# The LLM-as-judge (notebook 05) uses an OpenAI-COMPATIBLE client, so the same
# code points at either a local server or a cloud endpoint -- only these three
# variables change.
#
# Local (llama.cpp / LM Studio / Ollama OpenAI-compatible server): no real key.
#   LLM_BASE_URL=http://127.0.0.1:8080/v1
#   LLM_API_KEY=sk-no-key-required
#   LLM_MODEL=qwen3
#
# Cloud (example — OpenAI): a real key, shared with the judge owner via a
# private channel, never through GitHub.
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_API_KEY=sk-...your-key...
#   LLM_MODEL=gpt-4o-mini

LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
